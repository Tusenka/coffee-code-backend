{
	"version": 1,
	"loggers": {
		"root": {
			"level": "NOTSET",
			"handlers": ["console"]
		}
	},
	"handlers": {
		"console": {
			"class": "logging.StreamHandler",
			"level": "DEBUG",
			"formatter": "json"
		}
	},
	"formatters": {
		"json": {"class": "utils.logger.JsonFormatter.JsonFormatter"}
	},
	"disable_existing_loggers": false
}